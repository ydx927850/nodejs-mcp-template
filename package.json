{
  "name": "chairmosn",
  "description": "",
  "repository": "git@code.alipay.com:chair/examples.git",
  "dependencies": {
    "@eggjs/tsconfig": "^1.0.0",
    "chair": "release-2",
    "enums": "^1.0.0",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@ali/ci": "4",
    "@alipay/chair-bin": "6",
    "@types/mocha": "10",
    "@utoo/pack": "1.3.0-alpha.0",
    "@utoo/pack-cli": "1.3.0-alpha.0",
    "eslint": "8",
    "eslint-config-egg": "12"
  },
  "scripts": {
    "build": "NODE_ENV=production tnpx up build && node scripts/pre-deploy.js",
    "dev": "NODE_ENV=development tnpx up dev && node scripts/pre-deploy.js",
    "debug": "chair-bin debug",
    "module": "chair-bin module type",
    "lint": "eslint . --ext .ts",
    "test": "npm run lint && npm run test-local",
    "test-local": "chair-bin test",
    "cov": "chair-bin cov",
    "ci": "npm run lint && npm run cov"
  },
  "config": {
    "jar2proxy": false,
    "buildAssets": false,
    "deployAssets": false
  },
  "egg": {
    "typescript": true,
    "declarations": true
  },
  "engines": {
    "install-node": "22"
  },
  "private": true
